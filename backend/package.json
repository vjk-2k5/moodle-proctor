{
  "name": "moodle-proctor-backend",
  "version": "1.0.0",
  "description": "Unified backend for Moodle-Proctor system with Fastify and TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx scripts/migrate.ts up",
    "migrate:status": "tsx scripts/migrate.ts status",
    "seed": "tsx scripts/seed.ts seed",
    "seed:clear": "tsx scripts/seed.ts clear",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "moodle",
    "proctor",
    "fastify",
    "typescript",
    "websocket"
  ],
  "author": "Moodle-Proctor Team",
  "license": "MIT",
  "dependencies": {
    "@fastify/cookie": "^9.3.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^7.2.4",
    "@fastify/postgres": "^5.2.0",
    "@fastify/websocket": "^8.3.0",
    "axios": "^1.6.5",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.0",
    "fastify-sse-v2": "^4.2.2",
    "pg": "^8.11.3",
    "winston": "^3.11.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
