<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/dscproctor/db" VERSION="2026040800" COMMENT="Moodle-native proctoring rewrite foundation"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="local_dscproctor_exam" COMMENT="Native Moodle-side exam registry for the rewrite">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="cmid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="sourcequizid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="legacyexamid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="examname" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="defaultquestionpaper" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="durationminutes" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="maxwarnings" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="15"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="draft"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid_ix" UNIQUE="false" FIELDS="courseid"/>
        <INDEX NAME="legacyexamid_ix" UNIQUE="false" FIELDS="legacyexamid"/>
        <INDEX NAME="status_ix" UNIQUE="false" FIELDS="status"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_dscproctor_assign" COMMENT="Teacher-owned exam assignments that students see in Moodle and launch in Electron">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="examid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="teacheruserid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="assignmentname" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="timestart" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timefinish" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="durationminutes" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="questionpaper" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="aienabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="proctoringenabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="legacyroomcode" TYPE="char" LENGTH="32" NOTNULL="false"/>
        <FIELD NAME="legacylaunchurl" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="scheduled"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="examid_fk" TYPE="foreign" FIELDS="examid" REFTABLE="local_dscproctor_exam" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="teacheruserid_ix" UNIQUE="false" FIELDS="teacheruserid"/>
        <INDEX NAME="timestart_ix" UNIQUE="false" FIELDS="timestart"/>
        <INDEX NAME="status_ix" UNIQUE="false" FIELDS="status"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_dscproctor_asgnusr" COMMENT="Students assigned to a teacher-created assignment">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="assignmentid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="assigned"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="assignmentid_fk" TYPE="foreign" FIELDS="assignmentid" REFTABLE="local_dscproctor_assign" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="assignmentuserid_uix" UNIQUE="true" FIELDS="assignmentid, userid"/>
        <INDEX NAME="userid_ix" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="status_ix" UNIQUE="false" FIELDS="status"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_dscproctor_room" COMMENT="Native Moodle-side room registry for live proctoring">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="examid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="owneruserid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="legacyroomid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="roomcode" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="created"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="examid_fk" TYPE="foreign" FIELDS="examid" REFTABLE="local_dscproctor_exam" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="roomcode_uix" UNIQUE="true" FIELDS="roomcode"/>
        <INDEX NAME="owneruserid_ix" UNIQUE="false" FIELDS="owneruserid"/>
        <INDEX NAME="status_ix" UNIQUE="false" FIELDS="status"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_dscproctor_attempt" COMMENT="Native Moodle-side attempts for the rewrite">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="examid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="roomid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="legacyattemptid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="not_started"/>
        <FIELD NAME="warningcount" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="submissionreason" TYPE="char" LENGTH="50" NOTNULL="false"/>
        <FIELD NAME="timestarted" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="timefinished" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="examid_fk" TYPE="foreign" FIELDS="examid" REFTABLE="local_dscproctor_exam" REFFIELDS="id"/>
        <KEY NAME="roomid_fk" TYPE="foreign" FIELDS="roomid" REFTABLE="local_dscproctor_room" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="examuserid_ix" UNIQUE="false" FIELDS="examid, userid"/>
        <INDEX NAME="legacyattemptid_ix" UNIQUE="false" FIELDS="legacyattemptid"/>
        <INDEX NAME="status_ix" UNIQUE="false" FIELDS="status"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_dscproctor_violation" COMMENT="Native Moodle-side violation log for the rewrite">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="attemptid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="violationtype" TYPE="char" LENGTH="100" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="severity" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="warning"/>
        <FIELD NAME="detail" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="metadata" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="attemptid_fk" TYPE="foreign" FIELDS="attemptid" REFTABLE="local_dscproctor_attempt" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="attemptid_ix" UNIQUE="false" FIELDS="attemptid"/>
        <INDEX NAME="severity_ix" UNIQUE="false" FIELDS="severity"/>
        <INDEX NAME="violationtype_ix" UNIQUE="false" FIELDS="violationtype"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
